      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="_prop_cb10243f938f" name="description">
        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#String"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_1dd056c05d2f" name="actor" isOrdered="false" type="_cls_14ab235783d2"/>
      <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_3f3f775dc01b" name="purpose" isOrdered="false" type="_cls_c4ce0d15445a">
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_uv_c6220c3bf907" value=""/>
        <ownedComment xmi:type="uml:Comment" xmi:id="_cmt_4d5ced9f1f09">
          <body>Every processing activity has at least one explicit purpose.</body>
        </ownedComment>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_826f4a1e6012" name="processingActivity" isOrdered="false" type="_cls_8a62db5f5283">
        <ownedComment xmi:type="uml:Comment" xmi:id="_cmt_5935a3497935">
          <body>One processing activity may appear in multiple statements.</body>
        </ownedComment>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_9bfff47d9812" name="legalBasis" isOrdered="false" type="_cls_80a7c971fce9">
        <ownedComment xmi:type="uml:Comment" xmi:id="_cmt_7a12ba4940aa">
          <body>Every policy statement must be legally justified.</body>
        </ownedComment>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_411fda73c1b5" name="governingRegulations" isOrdered="false" type="_cls_ca63472d42f1">
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_uv_f7cb43d5ee8d" value=""/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_cdbc45b0e1af" name="constraints" isOrdered="false" type="_cls_6db2dca946fa">
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_uv_de1825e52802" value=""/>
        <ownedComment xmi:type="uml:Comment" xmi:id="_cmt_46052db69537">
          <body>Allows constraint reuse, constraint libraries, cross-policy comparison.</body>
        </ownedComment>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_d490ffa7b458" name="rightImpacted" isOrdered="false" type="_cls_a69868914228">
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_uv_2e915f3351ef" value=""/>
      </ownedAttribute>
      <ownedRule xmi:type="uml:Constraint" xmi:id="_con_f6607b989414" name="constraint_2" constrainedElement="_cls_73202bbe1681">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_oex_cfad376e960d">
          <language>OCL</language>
          <body>governingRegulations-&gt;forAll(r | r.jurisdiction-&gt;notEmpty())</body>
        </specification>
      </ownedRule>
    </packagedElement>
  </packagedElement>
