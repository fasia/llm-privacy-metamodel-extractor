        <type xmi:type="uml:PrimitiveType" href="pathmap://UML_LIBRARIES/UMLPrimitiveTypes.library.uml#Long"/>
      </ownedAttribute>
      <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_d61a16186e55" name="statements" isOrdered="false" aggregation="composite" type="_cls_73202bbe1681">
        <upperValue xmi:type="uml:LiteralUnlimitedNatural" xmi:id="_uv_63e11dd80aef" value=""/>
      </ownedAttribute>
      <ownedRule xmi:type="uml:Constraint" xmi:id="_con_90b278715af0" name="constraint01" constrainedElement="_cls_ea813403d184">
        <specification xmi:type="uml:OpaqueExpression" xmi:id="_oex_1f04111b0bd4">
          <language>OCL</language>
          <body>statements-&gt;size() &gt; 0</body>
        </specification>
      </ownedRule>
    </packagedElement>
    <packagedElement xmi:type="uml:Class" xmi:id="_cls_73202bbe1681" name="PolicyStatement">
      <ownedAttribute xmi:type="uml:Property" xmi:id="_prop_316e13aa6bee" name="statementId">
