    <packagedElement xmi:type="uml:Package" xmi:id="_pkg_f29ec76a536a4a45" name="Legal">
      <packagedElement xmi:type="uml:Class" xmi:id="_cls_10e72e400b904a9d" name="LegalBasis">
        <ownedAttribute xmi:type="uml:Property" xmi:id="_prop_6ee0b9f1024b42cb" name="basisId">
          <type xmi:type="uml:PrimitiveType" href="http://schema.omg.org/spec/UML/2.1/uml.xml#String"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_prop_4ffd3da2d1d1479d" name="type" type="_enum_f77c36da1b9c45d9"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_prop_6bb24e2ca1ca4631" name="evidence">
          <type xmi:type="uml:PrimitiveType" href="http://schema.omg.org/spec/UML/2.1/uml.xml#String"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_6775825a8b134ccb" name="jurisdiction" type="_cls_e874e3c87e184997" upper="*">
          <ownedComment xmi:type="uml:Comment" xmi:id="_cmt_505d589960a246d4"><body><![CDATA[Replaces the former free-text 'jurisdiction' string. References the canonical Jurisdiction instances in RegulatoryContext, preventing synonymous strings (EU / European Union / Europe) for the same jurisdiction and enabling cross-law queries.]]></body></ownedComment>
        </ownedAttribute>
      </packagedElement>
    </packagedElement>
    <packagedElement xmi:type="uml:Package" xmi:id="_pkg_f61599baca384338" name="Processing">
      <packagedElement xmi:type="uml:Class" xmi:id="_cls_e02e37ba224b4dd6" name="ProcessingActivity">
        <ownedAttribute xmi:type="uml:Property" xmi:id="_prop_ec565820f35b4419" name="activityId">
          <type xmi:type="uml:PrimitiveType" href="http://schema.omg.org/spec/UML/2.1/uml.xml#String"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_prop_ca516301838544fb" name="description">
          <type xmi:type="uml:PrimitiveType" href="http://schema.omg.org/spec/UML/2.1/uml.xml#String"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_prop_84244aeb2e5c4c28" name="action" type="_enum_be3e00bfca1f4e6c"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_prop_70fdef6270aa4562" name="riskAssessmentReference" lower="0">
          <type xmi:type="uml:PrimitiveType" href="http://schema.omg.org/spec/UML/2.1/uml.xml#String"/>
          <ownedComment xmi:type="uml:Comment" xmi:id="_cmt_bb5eb848220f4070"><body><![CDATA[Law-neutral reference to any form of impact or risk assessment document (DPIA under GDPR Art.35, RIPD under LGPD Art.38, risk assessment under CPRA, voluntary PIA under PIPEDA). Absence on high-risk activities is a compliance gap signal, not a hard conformance error.]]></body></ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_3a1c7478dce24638" name="dataProcessed" type="_cls_b13b2ebef9554008" upper="*">
          <ownedComment xmi:type="uml:Comment" xmi:id="_cmt_8fb24ba8f44b4922"><body><![CDATA[One activity to many data categories; one data category to many activities.]]></body></ownedComment>
        </ownedAttribute>
        <ownedRule xmi:type="uml:Constraint" xmi:id="_con_de74f30441e74dc7" name="constraint_3__warning" constrainedElement="_cls_e02e37ba224b4dd6">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="_oex_df750c37c7234677">
            <language>OCL</language>
            <body><![CDATA[(self.action = ProcessingAction::Transfer or self.action = ProcessingAction::Share) and self.dataProcessed->exists(d | d.sensitivity = SensitivityLevel::SpecialCategory or d.sensitivity = SensitivityLevel::High) implies self.riskAssessmentReference->notEmpty()]]></body>
          </specification>
          <ownedComment xmi:type="uml:Comment" xmi:id="_cmt_d4a06c2a4b504a62"><body><![CDATA[High-risk Transfer or Share of sensitive data has no risk assessment reference. This is a hard violation under GDPR Art.35 and LGPD Art.38, a regulatory obligation under CPRA, and a best-practice recommendation under PIPEDA.]]></body></ownedComment>
        </ownedRule>
      </packagedElement>
    </packagedElement>
