          <type xmi:type="uml:PrimitiveType" href="http://schema.omg.org/spec/UML/2.1/uml.xml#String"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_prop_2b8d7ce1f8124821" name="validFrom">
          <type xmi:type="uml:PrimitiveType" href="http://schema.omg.org/spec/UML/2.1/uml.xml#Long"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_prop_2aa2625ae3934e47" name="validTo">
          <type xmi:type="uml:PrimitiveType" href="http://schema.omg.org/spec/UML/2.1/uml.xml#Long"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_837a4913d90a4349" name="statements" type="_cls_5d50ccba7f9d49ab" upper="*" aggregation="composite"/>
        <ownedRule xmi:type="uml:Constraint" xmi:id="_con_213f1af2351642ee" name="constraint01" constrainedElement="_cls_e0240ebfcb664942">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="_oex_d2d0b4df6edf4bb7">
            <language>OCL</language>
            <body><![CDATA[statements->size() > 0]]></body>
          </specification>
        </ownedRule>
      </packagedElement>
      <packagedElement xmi:type="uml:Class" xmi:id="_cls_5d50ccba7f9d49ab" name="PolicyStatement">
        <ownedAttribute xmi:type="uml:Property" xmi:id="_prop_cf17eca7fa644574" name="statementId">
          <type xmi:type="uml:PrimitiveType" href="http://schema.omg.org/spec/UML/2.1/uml.xml#String"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_prop_46c39b214ac54b59" name="description">
          <type xmi:type="uml:PrimitiveType" href="http://schema.omg.org/spec/UML/2.1/uml.xml#String"/>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_c509605b22484388" name="actor" type="_cls_64529e6afdce4829"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_b2fab5fc10ac4fcd" name="purpose" type="_cls_de2989ce0d314db2" upper="*">
          <ownedComment xmi:type="uml:Comment" xmi:id="_cmt_2428780de7ec4f83"><body><![CDATA[Every processing activity has at least one explicit purpose.]]></body></ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_948db6d264e24897" name="processingActivity" type="_cls_e02e37ba224b4dd6">
          <ownedComment xmi:type="uml:Comment" xmi:id="_cmt_afa343949be34e6a"><body><![CDATA[One processing activity may appear in multiple statements.]]></body></ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_a37c94204900424f" name="legalBasis" type="_cls_10e72e400b904a9d">
          <ownedComment xmi:type="uml:Comment" xmi:id="_cmt_63aa9e7e40c447f9"><body><![CDATA[Every policy statement must be legally justified.]]></body></ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_929acac8efb7498b" name="governingRegulations" type="_cls_5362fd3767514d43" upper="*"/>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_eb1cd9375eba437a" name="constraints" type="_cls_061b9994d8fe4d65" upper="*">
          <ownedComment xmi:type="uml:Comment" xmi:id="_cmt_3f04ae3fe58b4c2a"><body><![CDATA[Allows constraint reuse, constraint libraries, cross-policy comparison.]]></body></ownedComment>
        </ownedAttribute>
        <ownedAttribute xmi:type="uml:Property" xmi:id="_ref_a0589c5abea543f0" name="rightImpacted" type="_cls_25a457d7eae744a4" upper="*"/>
        <ownedRule xmi:type="uml:Constraint" xmi:id="_con_29b4c79ab7bd4227" name="constraint_2" constrainedElement="_cls_5d50ccba7f9d49ab">
          <specification xmi:type="uml:OpaqueExpression" xmi:id="_oex_137573d6c8264b29">
            <language>OCL</language>
            <body><![CDATA[governingRegulations->forAll(r | r.jurisdiction->notEmpty())]]></body>
          </specification>
        </ownedRule>
      </packagedElement>
    </packagedElement>
